{
  "name": "bookie-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "cd ../backend && ./gradlew bootRun",
    "dev:all": "concurrently --kill-others-on-fail -n backend,frontend -c green,blue \"npm run dev:backend\" \"npm run dev\"",
    "generate:api": "openapi-generator-cli generate -i http://localhost:48763/v3/api-docs -g typescript-fetch -o src/generated/api --additional-properties=typescriptThreePlus=true,supportsES6=true --type-mappings=date=string,DateTime=string",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .js,.jsx",
    "test:visual": "playwright test -c playwright.visual.config.js",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "tauri": "tauri",
    "dev:tauri": "tauri dev",
    "build:tauri": "tauri build"
  },
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/dates": "^8.3.18",
    "@mantine/form": "^9.1.0",
    "@mantine/hooks": "^8.3.18",
    "@mantine/modals": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@tabler/icons-react": "^3.41.0",
    "@tanstack/react-query": "^5.100.5",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "dayjs": "^1.11.20",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@openapitools/openapi-generator-cli": "^2.39.1",
    "@playwright/test": "^1.55.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^26.0.0",
    "prettier": "^3.8.3",
    "typescript": "^7.0.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.0",
    "zod": "^4.4.3"
  },
  "volta": {
    "node": "22.22.2"
  }
}
