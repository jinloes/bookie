# Path to npm binary (required if npm is not on the default PATH, e.g. when using Volta or nvm)
# NPM_PATH=/Users/yourname/.volta/bin/npm

# AI service settings (optional overrides)
# AI_CLI_PATH=/usr/local/bin/ai-cli
# AI_USE_LOGGED_IN_USER=true
# AI_AUTH_TOKEN=token_here
# AI_MODEL_AGENT=gpt-4.1
# AI_MODEL_CHAT=gpt-4.1
# AI_MODEL_VISION=gpt-4.1
# AI_REQUEST_TIMEOUT_MS=180000

OUTLOOK_CLIENT_ID=your_azure_client_id
OUTLOOK_CLIENT_SECRET=your_azure_client_secret
OUTLOOK_TENANT_ID=your_azure_tenant_id
