# ============================================================================
# DATA STORAGE
# ============================================================================
# Location where Bookie stores its H2 database file
# Default: ~/.bookie/
BOOKIE_DATA_DIR=${user.home}/.bookie

# ============================================================================
# AI & LANGUAGE MODELS
# ============================================================================
# Copilot SDK authentication token (if using Copilot for email parsing/receipts)
# Leave empty to skip Copilot integration; Spring AI (OpenAI) will be used instead
AI_AUTH_TOKEN=

# Whether to use the currently logged-in user's Copilot credentials
# Set to 'true' to use system user's Copilot auth
AI_AUTH_USE_LOGGED_IN_USER=true

# Copilot CLI executable path (auto-detected if not provided)
AI_CLI_PATH=

# LLM model for email parsing and receipt OCR (e.g., gpt-4-vision, gpt-4o, claude-3)
AI_MODEL_VISION=gpt-4o

# LLM model for chat/agent conversations (e.g., gpt-4, gpt-4-turbo, claude-3)
AI_MODEL_CHAT=gpt-4

# LLM model for agent (e.g., gpt-4o, claude-3)
AI_MODEL_AGENT=gpt-4o

# Request timeout for LLM calls in milliseconds
# Default: 180000 (3 minutes)
AI_REQUEST_TIMEOUT_MS=180000

# Enable email parser tools (advanced; requires Copilot SDK setup)
# Default: false
AI_TOOLS_EMAIL_PARSER_ENABLED=false

# Enable tracing of tool execution events (generates verbose logs)
# Default: false
AI_TOOLS_TRACE_EVENTS=false

# OpenAI API key (if not using Copilot)
SPRING_AI_OPENAI_API_KEY=

# ============================================================================
# OUTLOOK INTEGRATION (Microsoft Azure)
# ============================================================================
# Azure Active Directory application (client) ID for OAuth
OUTLOOK_CLIENT_ID=your_azure_client_id

# Azure AD application secret
OUTLOOK_CLIENT_SECRET=your_azure_client_secret

# Azure AD tenant ID
OUTLOOK_TENANT_ID=your_azure_tenant_id

# ============================================================================
# SECURITY & CORS
# ============================================================================
# Comma-separated list of allowed origins for CORS
# Default: http://localhost:5173,tauri://localhost,https://tauri.localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,tauri://localhost,https://tauri.localhost

# ============================================================================
# TAURI DESKTOP APP
# ============================================================================
# Backend root directory (path to 'backend/' folder)
# If not set, Tauri will search up from the executable for gradlew
# Set this if installation is in a non-standard location
BOOKIE_BACKEND_ROOT=

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================
# Spring Boot log level (DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BOOKIE=INFO
LOGGING_LEVEL_COM_BOOKIE_SERVICE_EMAIL_PARSER_SERVICE=DEBUG
LOGGING_LEVEL_COM_BOOKIE_SERVICE_EMAIL_PARSER_TOOLS=DEBUG
LOGGING_LEVEL_COM_BOOKIE_SERVICE_OUTLOOK_SERVICE=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB_CLIENT=DEBUG
