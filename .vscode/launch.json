{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Bookie Backend",
      "type": "java",
      "request": "launch",
      "mainClass": "com.bookie.BookieApplication",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Frontend Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Tauri Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev:tauri",
      "cwd": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Bookie",
      "configurations": ["Bookie Backend", "Tauri Dev"],
      "stopAll": true
    },
    {
      "name": "Bookie Web",
      "configurations": ["Bookie Backend", "Frontend Dev"],
      "stopAll": true
    }
  ]
}
